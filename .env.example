# Copy to .env and uncomment the mode you need.

# --- Phone dev (hotspot + Windows portproxy) ---
# PC connected to phone hotspot; portproxy forwards Windows IP -> WSL
# Metro default port is 8081 — add portproxy rule for 8081 if you only had 3000 before.
# REACT_NATIVE_PACKAGER_HOSTNAME=172.20.10.2
# EXPO_PACKAGER_HOSTNAME=172.20.10.2

# --- Web on this PC ---
# REACT_NATIVE_PACKAGER_HOSTNAME=localhost
# EXPO_PACKAGER_HOSTNAME=localhost
