{
  "name": "audio-cards",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "start:phone": "REACT_NATIVE_PACKAGER_HOSTNAME=172.20.10.2 EXPO_PACKAGER_HOSTNAME=172.20.10.2 expo start --dev-client",
    "start:go": "expo start",
    "start:web": "expo start --web",
    "start:tunnel": "REACT_NATIVE_PACKAGER_HOSTNAME= EXPO_PACKAGER_HOSTNAME= expo start --dev-client --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-test-module-mocks --import tsx --import ./test/setup.mjs --test src/**/__tests__/**/*.test.ts",
    "test:watch": "node --experimental-test-module-mocks --import tsx --import ./test/setup.mjs --test --watch src/**/__tests__/**/*.test.ts",
    "test:e2e": "maestro test .maestro/",
    "build:ios": "eas build --profile production --platform ios",
    "submit:ios": "eas submit --platform ios",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "@react-native-community/slider": "4.5.5",
    "@react-navigation/native": "^7.0.14",
    "@types/jszip": "^3.4.0",
    "base64-js": "^1.5.1",
    "drizzle-orm": "^0.39.3",
    "expo": "~52.0.46",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-constants": "~17.0.8",
    "expo-dev-client": "~5.0.20",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.5",
    "expo-router": "~4.0.20",
    "expo-speech": "~13.0.1",
    "expo-speech-recognition": "^1.1.1",
    "expo-splash-screen": "~0.29.24",
    "expo-sqlite": "~15.1.4",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "fzstd": "^0.1.1",
    "jszip": "^3.10.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gifted-charts": "^1.4.58",
    "react-native-reanimated": "~3.16.7",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-web": "~0.19.13",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "babel-plugin-inline-import": "^3.0.0",
    "drizzle-kit": "^0.30.5",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.1",
    "tsx": "^4.19.4",
    "typescript": "~5.3.3"
  },
  "private": true
}
